# Lesson Service Environment Variables

# ==================== Server Configuration ====================
SERVER_PORT=8083

# ==================== Database Configuration ====================
DB_URL=jdbc:mysql://localhost:3306/edulearn_lesson?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=root123
DB_DRIVER=com.mysql.cj.jdbc.Driver

# ==================== JPA/Hibernate Configuration ====================
JPA_HIBERNATE_DDL_AUTO=update
JPA_SHOW_SQL=false
JPA_DIALECT=org.hibernate.dialect.MySQLDialect

# ==================== JWT Configuration ====================
JWT_SECRET=mySecretKeyForJWTAuthenticationInEduLearnMicroserviceArchitecture2024SuperSecureKey123!@#
JWT_EXPIRATION=86400000

# ==================== Application Configuration ====================
SPRING_APPLICATION_NAME=lesson-service

# ==================== Logging Configuration ====================
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_EDULEARN=DEBUG

