# Auth Service Environment Variables

# ==================== Server Configuration ====================
SERVER_PORT=8081

# ==================== Database Configuration ====================
DB_URL=jdbc:mysql://localhost:3306/edulearn_auth?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=root123
DB_DRIVER=com.mysql.cj.jdbc.Driver

# ==================== JPA/Hibernate Configuration ====================
JPA_HIBERNATE_DDL_AUTO=update
JPA_SHOW_SQL=false
JPA_DIALECT=org.hibernate.dialect.MySQLDialect

# ==================== JWT Configuration ====================
JWT_SECRET=mySecretKeyForJWTAuthenticationInEduLearnMicroserviceArchitecture2024SuperSecureKey123!@#
JWT_EXPIRATION=86400000

# ==================== Google OAuth2 Configuration ====================
# Get these from Google Cloud Console: https://console.cloud.google.com
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# ==================== Application Configuration ====================
SPRING_APPLICATION_NAME=auth-service

# ==================== Logging Configuration ====================
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_EDULEARN=DEBUG

